{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 120,
  "proseWrap": "always",
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": [
    "packages/*/tests/**/fixtures/**",
    "packages/*/test/**/fixtures*/**",
    "packages/*/benchmarks/**/fixtures*/**",
    "packages/*/lib",
    "packages/*/dist",
    "packages/edge-bundler/deno/**",
    "packages/edge-bundler/*/vendor/**",
    "CHANGELOG.md",
    "coverage"
  ]
}
